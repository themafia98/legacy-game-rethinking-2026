rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      function validName(name) {
        return name is string
          && name.size() >= 1
          && name.size() <= 11
          && name.matches('^[A-Za-z0-9_-]+$');
      }

      function validPoints(points) {
        return points is int
          && points >= 0
          && points <= 1000000;
      }

      // Anyone can read leaderboard entries
      allow read: if true;

      // Public leaderboard docs expose only display-safe fields.
      allow create: if request.resource.data.keys().hasOnly(['name', 'points'])
                    && validName(request.resource.data.name)
                    && validPoints(request.resource.data.points);

      // No client-side updates or deletes
      allow update, delete: if false;
    }
  }
}
