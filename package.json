{
  "name": "arena-game",
  "version": "2.0.0",
  "description": "ARENA - Canvas game refactored to TypeScript",
  "scripts": {
    "dev": "yarn build:wasm:dev && vite",
    "build": "yarn build:wasm && tsc --noEmit && vite build",
    "build:wasm": "asc assembly/index.ts --config assembly/asconfig.json --target release --outFile public/game.wasm",
    "build:wasm:dev": "asc assembly/index.ts --config assembly/asconfig.json --target debug --outFile public/game.wasm",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "yarn build && firebase deploy --only hosting,firestore:rules",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "clean": "del-cli dist"
  },
  "type": "module",
  "author": "themafia98",
  "license": "ISC",
  "dependencies": {
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "assemblyscript": "^0.28.17",
    "del-cli": "^5.1.0",
    "eslint": "^9.5.0",
    "typescript": "^5.5.2",
    "vite": "^8.0.13"
  }
}
